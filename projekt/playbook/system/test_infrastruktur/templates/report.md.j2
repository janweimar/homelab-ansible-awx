## 1. KURZÜBERSICHT

| Gesamtstatus | Module | Apps OK | Apps Warnung | Apps Fehler |
|---|---|---|---|---|
| {{ '❌ FEHLER' if gesamt_status == 'FEHLER' else '⚠️ WARNUNG' if gesamt_status == 'WARNUNG' else '✅ OK' }} | {{ alle_module_status | select('equalto', 'OK') | list | length }}/{{ alle_module_status | length }} OK | {{ app_ok }} | {{ app_warnung }} | {{ app_fehler }} |

---

{% set fehler_items = [] %}
{% set warnung_items = [] %}

{% for modul_name, modul_data in [
  ('System-Info', system_info_results),
  ('Pakete', pakete_results),
  ('Services', services_results),
  ('Benutzer', benutzer_results),
  ('Netzwerk', netzwerk_results),
  ('Ressourcen', ressourcen_results),
  ('Logs', logs_results),
  ('Sicherheit', sicherheit_results),
  ('Container', container_results),
  ('Hardware', hardware_results)
] %}
{% for detail in modul_data.details | default([]) %}
{% if detail.status == 'FEHLER' %}{% set _ = fehler_items.append({'modul': modul_name, 'name': detail.name, 'wert': detail.wert, 'hinweis': detail.hinweis}) %}{% endif %}
{% if detail.status == 'WARNUNG' %}{% set _ = warnung_items.append({'modul': modul_name, 'name': detail.name, 'wert': detail.wert, 'hinweis': detail.hinweis}) %}{% endif %}
{% endfor %}
{% endfor %}

