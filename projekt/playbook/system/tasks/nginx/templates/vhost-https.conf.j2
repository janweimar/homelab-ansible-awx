# {{ item.split('/')[0] }} - HTTPS Reverse Proxy
# Erstellt: {{ ansible_date_time.iso8601 }}

# HTTP → HTTPS Redirect
server {
    listen 80;
    server_name {{ item.split('/')[0] }};
    return 301 https://$host$request_uri;
}

# HTTPS
server {
    listen 443 ssl http2;
    server_name {{ item.split('/')[0] }};

    # SSL Zertifikate (Let's Encrypt)
    ssl_certificate {{ paths.letsencrypt_live[ansible_os_family] }}/{{ item.split('/')[0] }}/fullchain.pem;
    ssl_certificate_key {{ paths.letsencrypt_live[ansible_os_family] }}/{{ item.split('/')[0] }}/privkey.pem;

    # SSL Konfiguration (Modern)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Größere Uploads erlauben
    client_max_body_size 50M;

    # Logs
    access_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ item.split('/')[0] }}_ssl_access.log;
    error_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ item.split('/')[0] }}_ssl_error.log;

    # ModSecurity
    modsecurity on;
    modsecurity_rules_file {{ paths.modsecurity_conf[ansible_os_family] }};

    location / {
        {% if item.split('/')|length == 3 %}
        proxy_pass http://{{ item.split('/')[1] }}:{{ item.split('/')[2] }};
        {% else %}
        proxy_pass http://localhost:{{ item.split('/')[1] }};
        {% endif %}
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        
        # WebSocket Support
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
