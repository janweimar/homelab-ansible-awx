%YAML 1.1
---
# ============================================================
# 🛡️ Suricata Konfiguration
# Erstellt: {{ ansible_date_time.iso8601 }}
# Modus: {{ _suricata_mode | upper }}
# Interface: {{ _suricata_interface }}
# Traffic:   {{ _suricata_traffic }}
# ============================================================

# ── Netzwerk ──────────────────────────────────────────────
vars:
  address-groups:
    HOME_NET: "{{ _suricata_home_net }}"
    EXTERNAL_NET: "!$HOME_NET"
    HTTP_SERVERS: "$HOME_NET"
    SMTP_SERVERS: "$HOME_NET"
    SQL_SERVERS: "$HOME_NET"
    DNS_SERVERS: "$HOME_NET"
    TELNET_SERVERS: "$HOME_NET"
    AIM_SERVERS: "$EXTERNAL_NET"
    DC_SERVERS: "$HOME_NET"
    DNP3_SERVER: "$HOME_NET"
    DNP3_CLIENT: "$HOME_NET"
    MODBUS_CLIENT: "$HOME_NET"
    MODBUS_SERVER: "$HOME_NET"
    ENIP_CLIENT: "$HOME_NET"
    ENIP_SERVER: "$HOME_NET"

  port-groups:
    HTTP_PORTS: "80"
    SHELLCODE_PORTS: "!80"
    ORACLE_PORTS: 1521
    SSH_PORTS: 22
    DNP3_PORTS: 20000
    MODBUS_PORTS: 502
    FILE_DATA_PORTS: "[$HTTP_PORTS,110,143]"
    FTP_PORTS: 21
    GENEVE_PORTS: 6081
    VXLAN_PORTS: 4789
    TEREDO_PORTS: 3544

# ── Engine Einstellungen ──────────────────────────────────
default-log-dir: /var/log/suricata/

stats:
  enabled: yes
  interval: 8

# ── Outputs ───────────────────────────────────────────────
outputs:
  # EVE JSON Log (Hauptlog — für Wazuh/SIEM Integration)
  - eve-log:
      enabled: yes
      filetype: regular
      filename: eve.json
      community-id: true
      types:
        - alert:
            tagged-packets: yes
        - anomaly:
            enabled: yes
        - http:
            extended: yes
        - dns
        - tls:
            extended: yes
        - files:
            force-magic: no
        - smtp
        - flow
        - stats:
            totals: yes
            threads: no

  # Fast Log (einfache Alerts)
  - fast:
      enabled: yes
      filename: fast.log

  # Stats Log
  - stats:
      enabled: yes
      filename: stats.log
      append: yes
      totals: yes
      threads: no

# ── Capture ───────────────────────────────────────────────
{% if _suricata_mode == 'ids' %}
# IDS-Modus: af-packet (passiv, kein Eingriff in Traffic)
af-packet:
{% for _iface in _suricata_interface.split(',') %}
{% set _iface = _iface | trim %}
  - interface: {{ _iface }}
    cluster-id: {{ 99 + loop.index0 }}
    cluster-type: cluster_flow
    defrag: yes
    use-mmap: yes
    tpacket-v3: yes
{% if _suricata_traffic == 'web' %}
    # Nur HTTP/HTTPS Traffic überwachen (BPF-Filter)
    bpf-filter: "tcp port 80 or tcp port 443"
{% endif %}
{% endfor %}
{% elif _suricata_mode == 'ips' %}
# IPS-Modus: nfqueue (inline, blockiert Bedrohungen)
nfqueue:
  - queue-num: 0
    fail-open: yes
{% endif %}

# ── App-Layer Protokolle ──────────────────────────────────
app-layer:
  protocols:
    http:
      enabled: yes
      memcap: 64mb
    tls:
      enabled: yes
      detection-ports:
        dp: 443
    ssh:
      enabled: yes
    dns:
      enabled: yes
      tcp:
        enabled: yes
      udp:
        enabled: yes
    smtp:
      enabled: yes
    ftp:
      enabled: yes
    smb:
      enabled: yes
      detection-ports:
        dp: 139, 445
    nfs:
      enabled: yes
    rdp:
      enabled: yes
    mqtt:
      enabled: no
    http2:
      enabled: yes

# ── Detection Engine ─────────────────────────────────────
detect:
  profile: medium
  custom-values:
    toclient-groups: 3
    toserver-groups: 25
  sgh-mpm-context: auto
  inspection-recursion-limit: 3000

# ── Threading ─────────────────────────────────────────────
threading:
  set-cpu-affinity: no
  detect-thread-ratio: 1.0

# ── Stream Engine ─────────────────────────────────────────
stream:
  memcap: 64mb
  checksum-validation: yes
  inline: {{ 'auto' if _suricata_mode == 'ips' else 'no' }}
  reassembly:
    memcap: 256mb
    depth: 1mb
    toserver-chunk-size: 2560
    toclient-chunk-size: 2560

# ── Host/Flow Einstellungen ──────────────────────────────
flow:
  memcap: 128mb
  hash-size: 65536
  prealloc: 10000
  emergency-recovery: 30

host:
  hash-size: 4096
  prealloc: 1000
  memcap: 32mb

# ── Defrag ────────────────────────────────────────────────
defrag:
  memcap: 32mb
  hash-size: 65536
  trackers: 65535
  max-frags: 65535
  prealloc: yes
  timeout: 60

# ── Rules ─────────────────────────────────────────────────
default-rule-path: /var/lib/suricata/rules
rule-files:
  - suricata.rules

# ── Classification & Reference ────────────────────────────
classification-file: /etc/suricata/classification.config
reference-config-file: /etc/suricata/reference.config

# ── Logging ───────────────────────────────────────────────
logging:
  default-log-level: notice
  outputs:
    - console:
        enabled: yes
    - file:
        enabled: yes
        level: info
        filename: suricata.log
    - syslog:
        enabled: no

# ── Coredump ──────────────────────────────────────────────
coredump:
  max-dump: unlimited
