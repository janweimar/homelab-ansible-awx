---
###########################################################################
# Open WebUI Kubernetes Manifest
# DB: SQLite (intern, PVC fuer Persistenz)
# Verbindet sich mit Ollama ueber K8s internen DNS
# Externe Datenquellen (Qdrant, MariaDB) ueber K8s DNS erreichbar
###########################################################################
{% set _port = (app_port | default('', true) | string | trim) or '8080' %}

# Open WebUI Data PVC (SQLite + Uploads)
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ app_name }}-data-pvc
  namespace: {{ app_name }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 5Gi
---
# Open WebUI Deployment
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}
  namespace: {{ app_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: {{ app_name }}
  template:
    metadata:
      labels:
        app: {{ app_name }}
    spec:
{% if isolation_app | default(false) | bool %}
      # DNS nur cluster-intern — Open WebUI kann keine externen Domains aufloesen
      dnsPolicy: "None"
      dnsConfig:
        nameservers:
          - "10.43.0.10"       # K3s CoreDNS (nur cluster-intern)
        searches:
          - "ollama.svc.cluster.local"
          - "qdrant.svc.cluster.local"
          - "mariadb.svc.cluster.local"
          - "svc.cluster.local"
          - "cluster.local"
{% endif %}
      containers:
        - name: open-webui
          image: ghcr.io/open-webui/open-webui:main
{% if app_no_update | default(false) | bool %}
          imagePullPolicy: IfNotPresent
{% endif %}
          ports:
            - containerPort: {{ _port | int }}
          env:
            - name: OLLAMA_BASE_URL
              value: "http://ollama-service.ollama.svc.cluster.local:11434"
            - name: WEBUI_SECRET_KEY
              value: "{{ app_secret_key | default('') }}"
{% if app_admin_email | default('') | length > 0 %}
            - name: WEBUI_AUTH
              value: "true"
{% endif %}
          resources:
            requests:
              memory: "{{ app_resources[app_name].memory_request }}"
              cpu: "{{ app_resources[app_name].cpu_request }}"
            limits:
              memory: "{{ app_resources[app_name].memory_limit }}"
              cpu: "{{ app_resources[app_name].cpu_limit }}"
          volumeMounts:
            - name: data
              mountPath: /app/backend/data
          readinessProbe:
            httpGet:
              path: /health
              port: {{ _port | int }}
            initialDelaySeconds: 15
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 15
          livenessProbe:
            httpGet:
              path: /health
              port: {{ _port | int }}
            initialDelaySeconds: 60
            periodSeconds: 15
            timeoutSeconds: 5
            failureThreshold: 10
      volumes:
        - name: data
          persistentVolumeClaim:
            claimName: {{ app_name }}-data-pvc
---
# Open WebUI Service (NodePort)
apiVersion: v1
kind: Service
metadata:
  name: {{ app_name }}-service
  namespace: {{ app_name }}
spec:
  type: NodePort
  selector:
    app: {{ app_name }}
  ports:
    - port: {{ _port | int }}
      targetPort: {{ _port | int }}
