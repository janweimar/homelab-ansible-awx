# =============================================================================
# nginx vHost fuer AWX Execution Environment Docker Registry
# Domain: {{ server_urls.awx_ee.domain }}
# HTTP Reverse Proxy zur Docker Registry (READ-ONLY)
# =============================================================================

server {
    listen 80;
    server_name {{ server_urls.awx_ee.domain }};

    # Docker Images koennen gross sein
    client_max_body_size 0;
    chunked_transfer_encoding on;

    # Docker Registry API v2
    location /v2/ {
        # NUR lesender Zugriff von aussen (Pull)
        limit_except GET HEAD {
            deny all;
        }

        proxy_pass http://127.0.0.1:{{ server_urls.awx_ee.port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 900;
        proxy_connect_timeout 900;
        proxy_send_timeout 900;
    }

    location / {
        # NUR lesender Zugriff von aussen
        limit_except GET HEAD {
            deny all;
        }

        proxy_pass http://127.0.0.1:{{ server_urls.awx_ee.port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_read_timeout 900;
        proxy_connect_timeout 900;
        proxy_send_timeout 900;
    }
}
