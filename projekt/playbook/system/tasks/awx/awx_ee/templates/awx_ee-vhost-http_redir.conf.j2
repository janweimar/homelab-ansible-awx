# =============================================================================
# nginx vHost fuer AWX Execution Environment Docker Registry
# Domain: {{ server_urls.awx_ee.domain }}
# HTTP -> HTTPS Redirect
# =============================================================================

server {
    listen 80;
    server_name {{ server_urls.awx_ee.domain }};

    # Certbot Challenge
    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    # Redirect zu HTTPS
    location / {
        return 301 https://$host$request_uri;
    }
}
