# =============================================================================
# nginx vHost fuer BookStack Dokumentation
# Domain: {{ server_urls.bookstack.domain }}
# HTTPS Reverse Proxy
# =============================================================================

server {
    listen 443 ssl http2;
    server_name {{ server_urls.bookstack.domain }};

    # SSL Zertifikate (Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/{{ server_urls.bookstack.domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_urls.bookstack.domain }}/privkey.pem;

    # SSL Konfiguration (Modern)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Groessere Uploads erlauben (fuer Dokumente/Bilder in BookStack)
    client_max_body_size 50M;

    # Logs
    access_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ server_urls.bookstack.domain }}_ssl_access.log;
    error_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ server_urls.bookstack.domain }}_ssl_error.log;

{% if nginx_modsecurity | bool %}
    # ModSecurity
    modsecurity on;
    modsecurity_rules_file {{ paths.modsecurity_conf[ansible_os_family] }};
{% endif %}

    location / {
        proxy_pass http://127.0.0.1:{{ server_urls.bookstack.port }};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

        # WebSocket Support (fuer BookStack Live-Updates)
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Timeouts fuer grosse Uploads
        proxy_connect_timeout 600;
        proxy_send_timeout 600;
        proxy_read_timeout 600;
        send_timeout 600;
    }
}
