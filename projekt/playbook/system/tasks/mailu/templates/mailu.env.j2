# Mailu Konfiguration
# Generiert von Ansible — pb_setup_app_deploy.yml
# Referenz: https://setup.mailu.io/2024.06/

###########################################################################
# Basis-Konfiguration
###########################################################################

# Secret Key (Session-Verschlüsselung)
SECRET_KEY={{ app_secret_key }}

# Mail-Domain und Hostname
DOMAIN={{ urls[ansible_host].mailu.mail_domain }}
HOSTNAMES={{ urls[ansible_host].mailu.hostname }}

# Postmaster (bekommt DMARC-Reports)
POSTMASTER=postmaster

# Anzeigename der Website
SITENAME=Mailu - {{ urls[ansible_host].mailu.mail_domain }}

###########################################################################
# Netzwerk
###########################################################################

# IPv4-Adresse auf der mailu_front lauscht
# NIEMALS 0.0.0.0 — das würde Mailu zum Open-Relay machen!
# Immer die echte Server-IP setzen.
BIND_ADDRESS4={{ ansible_host }}

# Docker-Netzwerk Subnet (darf nicht mit bestehenden Netzen kollidieren)
SUBNET=192.168.203.0/24

# Nginx Reverse Proxy: echte Client-IP weitergeben
REAL_IP_HEADER=X-Forwarded-For
REAL_IP_FROM=127.0.0.1

###########################################################################
# TLS
###########################################################################

# notls = Mailu verwaltet kein TLS selbst
# TLS wird von nginx (davor) oder extern (STARTTLS) übernommen
TLS_FLAVOR=notls

###########################################################################
# Admin-UI
###########################################################################

# Admin-UI aktivieren
ADMIN=true

# Admin-UI Pfad
WEB_ADMIN=/admin

###########################################################################
# Features (deaktiviert)
###########################################################################

# Kein Webmail (nur Admin-GUI)
WEBMAIL=none

# Kein WebDAV
WEBDAV=none

# Kein Antivirus (ClamAV braucht >1GB RAM)
ANTIVIRUS=none

###########################################################################
# Rate Limiting
###########################################################################

# Fehlgeschlagene Logins pro IP pro Stunde
AUTH_RATELIMIT_IP=60/hour

# Fehlgeschlagene Logins pro User pro Tag
AUTH_RATELIMIT_USER=100/day

# Ausgehende Nachrichten pro User pro Tag
MESSAGE_RATELIMIT=200/day

# Maximale Nachrichtengröße (50 MB)
MESSAGE_SIZE_LIMIT=50000000

###########################################################################
# Datenbank (SQLite — kein externer DB-Container nötig)
###########################################################################

DB_FLAVOR=sqlite

###########################################################################
# Redis
###########################################################################

REDIS_ADDRESS=redis:6379

###########################################################################
# Initialer Admin-Account
# Wird nur beim ERSTEN Start gesetzt — danach ignoriert
###########################################################################

INITIAL_ADMIN_ACCOUNT=admin
INITIAL_ADMIN_DOMAIN={{ urls[ansible_host].mailu.mail_domain }}
INITIAL_ADMIN_PW={{ app_admin_password }}
INITIAL_ADMIN_MODE=ifmissing

###########################################################################
# Statistiken
###########################################################################

# Anonymisierte Statistiken deaktivieren
DISABLE_STATISTICS=true
