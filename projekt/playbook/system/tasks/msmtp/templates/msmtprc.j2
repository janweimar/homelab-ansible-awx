# Systemweite msmtp-Konfiguration
defaults
auth           on
tls            on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
logfile        /var/log/msmtp.log

account        {{ msmtp_account }}
host           {{ msmtp_host }}
port           {{ msmtp_port }}
from           {{ msmtp_from }}
user           {{ msmtp_user }}
password       {{ msmtp_password }}

account default : {{ msmtp_account }}
