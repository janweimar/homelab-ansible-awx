# =============================================================================
# nginx vHost fuer Wazuh Dashboard
# Domain: {{ server_urls.wazuh.domain }}
# HTTPS Reverse Proxy
# =============================================================================

server {
    listen 443 ssl http2;
    server_name {{ server_urls.wazuh.domain }};

    # SSL Zertifikate (Let's Encrypt)
    ssl_certificate /etc/letsencrypt/live/{{ server_urls.wazuh.domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ server_urls.wazuh.domain }}/privkey.pem;

    # SSL Konfiguration (Modern)
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers 'ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384';
    ssl_prefer_server_ciphers off;

    # HSTS
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Logs
    access_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ server_urls.wazuh.domain }}_ssl_access.log;
    error_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ server_urls.wazuh.domain }}_ssl_error.log;

{% if nginx_modsecurity | bool %}
    # ModSecurity
    modsecurity on;
    modsecurity_rules_file {{ paths.modsecurity_conf[ansible_os_family] }};
{% endif %}

    location / {
        proxy_pass https://127.0.0.1:5601;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;

        # SSL Backend (Wazuh Dashboard laeuft intern mit HTTPS)
        proxy_ssl_verify off;

        # Timeouts
        proxy_connect_timeout 300;
        proxy_send_timeout 300;
        proxy_read_timeout 300;
    }
}
