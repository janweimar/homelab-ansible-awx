# =============================================================================
# nginx vHost fuer Wazuh Dashboard
# Domain: {{ server_urls.wazuh.domain }}
# HTTP Reverse Proxy
# =============================================================================

server {
    listen 80;
    server_name {{ server_urls.wazuh.domain }};

    # Logs
    access_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ server_urls.wazuh.domain }}_access.log;
    error_log {{ paths.nginx_log_dir[ansible_os_family] }}/{{ server_urls.wazuh.domain }}_error.log;

{% if nginx_modsecurity | bool %}
    # ModSecurity
    modsecurity on;
    modsecurity_rules_file {{ paths.modsecurity_conf[ansible_os_family] }};
{% endif %}

    location / {
        proxy_pass https://127.0.0.1:5601;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # SSL Backend (Wazuh Dashboard laeuft intern mit HTTPS)
        proxy_ssl_verify off;

        # Timeouts
        proxy_connect_timeout 300;
        proxy_send_timeout 300;
        proxy_read_timeout 300;
    }
}
