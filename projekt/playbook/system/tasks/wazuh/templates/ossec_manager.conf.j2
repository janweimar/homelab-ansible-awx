  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/clamav/clamav.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/clamav/freshclam.log</location>
  </localfile>

  <!-- === Mailcow Log (Mail Server) === -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/mailcow.log</location>
  </localfile>
{% endif %}

{% if ansible_host == '<ip_odoo_server>' %}
  <!-- === Odoo Logs (<ip_odoo_server>) === -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/odoo/odoo-server.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/postgresql/postgresql-main.log</location>
  </localfile>

  <!-- === pgAudit Log (Odoo - DB Audit) === -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/postgresql/postgresql-*-main.log</location>
  </localfile>
{% endif %}

{% if ansible_host == '<ip_awx_server>' %}
  <!-- === Kubernetes / AWX Logs (<ip_awx_server>) === -->
  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/containers/*.log</location>
  </localfile>

  <localfile>
    <log_format>syslog</log_format>
    <location>/var/log/pods/**/*.log</location>
  </localfile>
{% endif %}

{% if ansible_host == '<ip_ai_server>' %}
  <!-- === Ollama / AI Logs (<ip_ai_server>) === -->
