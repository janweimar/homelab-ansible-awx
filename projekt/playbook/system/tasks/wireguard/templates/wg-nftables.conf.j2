#!/usr/sbin/nft -f
# ============================================================
# nftables - WireGuard VPN Regeln
# ============================================================
# Generated by Ansible - DO NOT EDIT MANUALLY
# ============================================================

# WireGuard VPN Port öffnen (WAN)
add rule inet filter input udp dport {{ vpn_port }} accept comment "WireGuard VPN"

# VPN Interface Traffic erlauben
add rule inet filter input iifname "{{ vpn_interface }}" accept comment "WireGuard VPN Interface"
add rule inet filter output oifname "{{ vpn_interface }}" accept comment "WireGuard VPN Interface"

# Forwarding für VPN-Clients
add rule inet filter forward iifname "{{ vpn_interface }}" accept comment "WireGuard Forward IN"
add rule inet filter forward oifname "{{ vpn_interface }}" accept comment "WireGuard Forward OUT"

# NAT/Masquerade für VPN-Clients (Zugriff auf Internet/Server-Netzwerk)
add rule inet nat postrouting oifname "{{ ansible_default_ipv4.interface }}" ip saddr {{ vpn_subnet }} masquerade comment "WireGuard NAT"
