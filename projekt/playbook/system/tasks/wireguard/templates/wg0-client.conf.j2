# ============================================================
# WireGuard VPN Client Configuration
# ============================================================
# Generated by Ansible - DO NOT EDIT MANUALLY
# Client: {{ client.name }}
# VPN IP: {{ client.vpn_ip }}
# ============================================================

[Interface]
# Client Details
Address = {{ client.vpn_ip }}/{{ vpn_subnet.split('/')[1] }}
PrivateKey = {{ client_private_key }}

# DNS via VPN (optional - erfordert resolvconf)
# DNS = 10.200.0.1

# ============================================================
# VPN Server
# ============================================================

[Peer]
# Server: {{ vpn_server_ip }}
PublicKey = {{ server_public_key }}

# Server Endpoint
Endpoint = {{ vpn_server_endpoint }}:{{ vpn_port }}

# Routed Traffic
# Option 1: Nur VPN-Subnet (Split-Tunnel)
AllowedIPs = {{ vpn_subnet }}

# Option 2: Alles über VPN (Full-Tunnel) - auskommentieren wenn gewünscht
# AllowedIPs = 0.0.0.0/0

# Keep Alive (wichtig für NAT)
PersistentKeepalive = 25
