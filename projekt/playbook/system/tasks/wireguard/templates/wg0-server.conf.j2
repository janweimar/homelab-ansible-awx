# ============================================================
# WireGuard VPN Server Configuration
# ============================================================
# Generated by Ansible - DO NOT EDIT MANUALLY
# ============================================================

[Interface]
# Server Details
Address = {{ vpn_server_ip }}/{{ vpn_subnet.split('/')[1] }}
ListenPort = {{ vpn_port }}
PrivateKey = {{ wg_private_key }}

# Forwarding & NAT wird über /etc/nftables.d/30-wireguard.nft verwaltet
# KEINE PostUp/PostDown hier - vermeidet doppelte Regeln

# ============================================================
# Clients
# ============================================================

{% for client in vpn_clients %}
# Client: {{ client.name }}
# Host: {{ client.ansible_host }}
[Peer]
PublicKey = {{ client.public_key }}
AllowedIPs = {{ client.vpn_ip }}/32
PersistentKeepalive = 25

{% endfor %}
